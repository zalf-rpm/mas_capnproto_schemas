from mas.schema.persistence.persistence_capnp.types.clients import PersistentClient
from mas.schema.registry.registry_capnp.types.clients import RegistryClient

class CropClient(IdentifiableClient, PersistentClient):
    def parameters(self) -> results_client.ParametersResult: ...
    def cultivar(self) -> results_client.CultivarResult: ...
    def species(self) -> results_client.SpeciesResult: ...
    def parameters_request(self) -> requests.ParametersRequest: ...
    def cultivar_request(self) -> requests.CultivarRequest: ...
    def species_request(self) -> requests.SpeciesRequest: ...

class ServiceClient(RegistryClient): ...
