"""Reader helper types for `sim_setup.capnp`."""

from collections.abc import Callable
from typing import override

from capnp.lib.capnp import (
    _DynamicStructReader,
)

from mas.schema.model.monica.sim_setup_capnp.types import builders as builders

class SetupReader(_DynamicStructReader):
    @property
    def runId(self) -> int: ...
    @property
    def sowingTime(self) -> str: ...
    @property
    def harvestTime(self) -> str: ...
    @property
    def cropId(self) -> str: ...
    @property
    def simJson(self) -> str: ...
    @property
    def cropJson(self) -> str: ...
    @property
    def siteJson(self) -> str: ...
    @property
    def startDate(self) -> str: ...
    @property
    def endDate(self) -> str: ...
    @property
    def groundwaterLevel(self) -> bool: ...
    @property
    def impenetrableLayer(self) -> bool: ...
    @property
    def elevation(self) -> bool: ...
    @property
    def slope(self) -> bool: ...
    @property
    def latitude(self) -> bool: ...
    @property
    def landcover(self) -> bool: ...
    @property
    def fertilization(self) -> bool: ...
    @property
    def nitrogenResponseOn(self) -> bool: ...
    @property
    def irrigation(self) -> bool: ...
    @property
    def waterDeficitResponseOn(self) -> bool: ...
    @property
    def emergenceMoistureControlOn(self) -> bool: ...
    @property
    def emergenceFloodingControlOn(self) -> bool: ...
    @property
    def leafExtensionModifier(self) -> bool: ...
    @property
    def co2(self) -> float: ...
    @property
    def o3(self) -> float: ...
    @property
    def fieldConditionModifier(self) -> float: ...
    @property
    def stageTemperatureSum(self) -> str: ...
    @property
    def useVernalisationFix(self) -> bool: ...
    @property
    def comment(self) -> str: ...
    @override
    def as_builder(
        self,
        num_first_segment_words: int | None = None,
        allocate_seg_callable: Callable[[int], bytearray] | None = None,
    ) -> builders.SetupBuilder: ...
